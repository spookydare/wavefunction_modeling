Cell["\<\
The following are other examples of a wave packets. Note the summation limits \
and their corresponding result on the wave packet.\
\>", "Text",
 CellChangeTimes->{{3.985443058674061*^9, 3.9854431078307037`*^9}, {
  3.9854431683377476`*^9, 
  3.985443175266985*^9}},ExpressionUUID->"961370a6-6a9c-8e42-a85b-\
8c4aa9e7132c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"y2", "[", "x_", "]"}], ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{"Cos", "[", 
     RowBox[{"2", "Pi", "*", 
      RowBox[{"(", 
       RowBox[{"n", "/", "20"}], ")"}], "*", "x"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "0", ",", "20"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"y2", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.985443129790474*^9, 3.98544314275362*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"a82ba6e3-5718-124c-81b9-df256fb818f8"],

