Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"l", " ", "=", " ", "1"}], ";", 
  RowBox[{"h", "=", 
   RowBox[{"1", "/", "2"}]}], ";", 
  RowBox[{
   RowBox[{"V", "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "1"}], "/", "x"}], "+", 
    RowBox[{"l", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"l", "+", "1"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", 
        RowBox[{"x", "^", "2"}]}], ")"}]}]}]}]}]}], "\n", 
 RowBox[{
  RowBox[{"L", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"h", "^", "2"}]}], "*", 
     RowBox[{
      RowBox[{"u", "''"}], "[", "x", "]"}]}], "+", 
    RowBox[{
     RowBox[{"V", "[", "x", "]"}], "*", 
     RowBox[{"u", "[", "x", "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Evalues", ",", "Efuncions"}], "}"}], "=", 
   RowBox[{"NDEigensystem", "[", 
    RowBox[{"L", ",", 
     RowBox[{"u", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", ".01", ",", "30"}], "}"}], ",", "5"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", "Evalues", "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"h", "*", "Efunctions"}], "+", "Evalues"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}], ",", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"V", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}], ",", 
   RowBox[{"AxesOrigin", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "3"}], ",", "0"}], "}"}]}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
