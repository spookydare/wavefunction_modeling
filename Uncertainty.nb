Cell[CellGroupData[{

Cell["Uncertainty", "Section",
 CellChangeTimes->{{3.9854425432568836`*^9, 
  3.985442545934561*^9}},ExpressionUUID->"f9bb0826-e20c-2a45-bfda-\
dea99f563235"],

Cell[CellGroupData[{

Cell["Classical Uncertainty: Waves", "Subsection",
 CellChangeTimes->{{3.9854425506587543`*^9, 
  3.985442560847357*^9}},ExpressionUUID->"bde4e168-8f6c-9843-b8f3-\
3b865cd61432"],

Cell["\<\
Uncertainty relations had been a well-known phenomenon for decades prior to \
the development of quantum mechanics. To explain what an uncertainty relation \
actually is, we need to define what a wave packet is. A single sine wave has \
a well-defined wavelength, amplitude, and phase. A wave packet is the \
summation of many similar sine waves that results in there being a large \
centralized peak at the center, and then to the left and right of that peak \
the amplitude asymptotically approaches zero. The following example \
demonstrates a wave packet.\
\>", "Text",
 CellChangeTimes->{{3.985442580765112*^9, 3.985442651708729*^9}, {
  3.985442693435177*^9, 3.985442821415144*^9}, {3.9854430137660465`*^9, 
  3.9854430264210815`*^9}},ExpressionUUID->"3a3c6359-8acb-f647-9128-\
ff55d53bb1ad"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"y1", "[", "x_", "]"}], ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{"Cos", "[", 
     RowBox[{"2", "Pi", "*", 
      RowBox[{"(", 
       RowBox[{"n", "/", "20"}], ")"}], "*", "x"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "0", ",", "100"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"y1", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9854429206320744`*^9, 3.9854429966020985`*^9}, {
  3.9854431144834023`*^9, 3.9854431209993496`*^9}},
