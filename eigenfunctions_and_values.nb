Cell["\<\
In this notebook i will use the basic functionality of NDEigensystem to \
evaluate the eigenvalues and eigenfunctions of a Schrodinger operator
you see the Evalues increase in discreet chunks. This is another way to \
approach quantization.\
\>", "Text",
 CellChangeTimes->{{3.985536837571262*^9, 3.985536909630105*^9}, 
   3.985537290007333*^9, {3.985537362245974*^9, 3.985537395881385*^9}, 
   3.9855377684431467`*^9},ExpressionUUID->"bdc700ae-caa7-4b37-be06-\
eeb36b0b8fef"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"h", "=", 
   RowBox[{"1", "/", "2"}]}], ";", 
  RowBox[{
   RowBox[{"V", "[", "x_", "]"}], ":=", 
   RowBox[{"x", "^", "2"}]}]}], "\n", 
 RowBox[{
  RowBox[{"l", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"h", "^", "2"}]}], "*", 
     RowBox[{
      RowBox[{"u", "''"}], "[", "x", "]"}]}], "+", 
    RowBox[{
     RowBox[{"V", "[", "x", "]"}], "*", 
     RowBox[{"u", "[", "x", "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Evalues", ",", "Efunctions"}], "}"}], "=", 
   RowBox[{"NDEigensystem", "[", 
    RowBox[{"l", ",", 
     RowBox[{"u", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", "5"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", "Evalues", "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"h", "*", "Efunctions"}], "+", "Evalues"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}], ",", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"V", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}], ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "5"}], "}"}]}], "}"}]}], ",", 
   RowBox[{"AxesOrigin", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "3"}], ",", "0"}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9855372921085873`*^9, 3.985537357755056*^9}, {
  3.9855374426362658`*^9, 3.985537445330709*^9}, {3.985537828399166*^9, 
  3.98553782860231*^9}, {3.9855382478393993`*^9, 3.985538276379183*^9}},
